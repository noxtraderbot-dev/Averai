    .hero { text-align: center; padding: 50px 0; }
    .features { display: grid; gap: 20px; margin-bottom: 40px; }
    .feature-card { background: #1e293b; padding: 20px; border-radius: 8px; }
  </style>
</head>
<body>

  <!-- Hero Section -->
  <div class="hero">
    <h1>Trade Crypto Smarter</h1>
    <p>Maximize your crypto profits with our expert guidance.</p>
  </div>

  <!-- Features -->
  <div class="features">
    <div class="feature-card">
      <h3>Cost-effectiveness</h3>
      <p>Benefit from competitive pricing and a wide selection of digital assets.</p>
    </div>
    <div class="feature-card">
      <h3>Easy Payments</h3>
      <p>Deposit and withdraw funds with multiple payment methods.</p>
    </div>
  </div>

  <!-- Clerk Registration Form -->
  <div id="sign-in"></div>

  <!-- Mandatory NYSE Footer -->
  <footer>
    <p>Aver is a registered trademark of The New York Stock Exchange (NYSE)</p>
    <p>The entire Aver project was run and built by the NYSE</p>
  </footer>

</body>
</html>
